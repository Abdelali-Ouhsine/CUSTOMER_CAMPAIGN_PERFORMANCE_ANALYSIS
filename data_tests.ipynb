  {
   "cell_type": "markdown",
   "id": "fe6956bb",
   "metadata": {},
   "source": [
    "## t-test or ANOVA to compare average sales amounts."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "66261295",
   "metadata": {},
   "source": [
    "### ANOVA checks whether the average sales of multiple groups are truly different, or if the differences you see are just due to random chance."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "33689aae",
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "5593493a",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "F_onewayResult(statistic=np.float64(990.7829788146964), pvalue=np.float64(0.0))"
      ]
     },
     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "stats.f_oneway(df[\"MntWines\"],\n",
    "               df[\"MntFruits\"],\n",
    "               df[\"MntMeatProducts\"],\n",
    "               df[\"MntFishProducts\"],\n",
    "               df[\"MntSweetProducts\"],\n",
    "               df[\"MntBakedProds\"]\n",
    "               )"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "900faa4a",
   "metadata": {},
   "source": [
    "####  Another ANOVA type"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "197d977d",
   "metadata": {},
   "outputs": [],
   "source": [
    "import statsmodels.api as sm\n",
    "from statsmodels.formula.api import ols"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "66602542",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "                        sum_sq      df           F        PR(>F)\n",
      "MntFruits         1.584829e+05     1.0    2.190003  1.390501e-01\n",
      "MntMeatProducts   2.826006e+07     1.0  390.512900  3.079221e-80\n",
      "MntFishProducts   3.216369e+04     1.0    0.444455  5.050487e-01\n",
      "MntSweetProducts  4.689024e+05     1.0    6.479549  1.097894e-02\n",
      "MntBakedProds     7.312309e+06     1.0  101.045473  2.786430e-23\n",
      "Residual          1.616668e+08  2234.0         NaN           NaN\n"
     ]
    }
   ],
   "source": [
    "model = ols('MntWines ~ MntFruits + MntMeatProducts + MntFishProducts + MntSweetProducts + MntBakedProds', data=df).fit()\n",
    "anova_res = sm.stats.anova_lm(model, typ=2)\n",
    "print(anova_res)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "27caa017",
   "metadata": {},
   "source": [
    "## Chi² for categorical variables (e.g., accepted campaign vs. country)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "6bb80203",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "chi2 statistic : 3.16\n",
      "p_value : 0.87\n",
      "Degree of freedom :7.00\n",
      "\n"
     ]
    }
   ],
   "source": [
    "accepted_campains = df[(df['AcceptedCmp1'] == 1) | (df['AcceptedCmp2'] == 1) |\n",
    "                    (df['AcceptedCmp3'] == 1) | (df['AcceptedCmp4'] == 1) |\n",
    "                    (df['AcceptedCmp5'] == 1) | (df['Response'] == 1)]\n",
    "alpha = 0.05\n",
    "contingency_table = pd.crosstab(df[\"AcceptedCmp1\"],df[\"Country\"])\n",
    "chi2, p_value, dof, expected = chi2_contingency(contingency_table)\n",
    "print(f\"chi2 statistic : {chi2:.2f}\")\n",
    "print(f\"p_value : {p_value:.2f}\")\n",
    "print(f\"Degree of freedom :{dof:.2f}\") \n",
    "\n",
    "if p_value > alpha:\n",
    "    print(\"\")"
   ]
  },
